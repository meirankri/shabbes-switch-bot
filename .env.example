# SwitchBot API Credentials
# Pour obtenir ces valeurs :
# 1. Ouvrez l'app SwitchBot
# 2. Profile > Preferences > About
# 3. Tapez 10 fois sur "App Version"
# 4. Developer Options > Get Token

token=VOTRE_TOKEN_ICI
secret=VOTRE_SECRET_ICI

# IDs de vos SwitchBot (à récupérer via le script test-api.js)
bot1=VOTRE_BOT1_ID_ICI
bot2=VOTRE_BOT2_ID_ICI

# Secret pour sécuriser le Cron Job (générez une chaîne aléatoire)
CRON_SECRET=VOTRE_SECRET_CRON_ICI
