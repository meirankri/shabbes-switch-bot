{
  "name": "switch-bot",
  "version": "1.0.0",
  "main": "index.ts",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon index",
    "start": "nodemon index",
    "prod": "pm2 start index.js --name shabbes-bot",
    "reload": "pm2 reload shabbes-bot",
    "scale1": "heroku scale worker=1",
    "scale0": "heroku scale worker=0",
    "disableweb": "heroku ps:scale web=0",
    "herokuRestart": "heroku restart -a shabes-bot2",
    "herkouPush": "git push heroku master",
    "herokuChangeApp": "heroku git:remote -a",
    "type-check": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "axios": "^0.21.1",
    "date-fns": "^2.21.3",
    "date-fns-tz": "^1.1.4",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "knex": "^0.95.6",
    "mysql": "^2.18.1",
    "nodemon": "^2.0.7",
    "pm2": "^5.1.0",
    "set-interval-async": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@vercel/node": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
